@bot.callback_query_handler(func=lambda call: True)
def callback_handler(call: types.CallbackQuery):
    chat_id = call.message.chat.id
    action = call.data
    
    if action == "main_menu":
        bot.edit_message_text("🌤️ *Главное меню*", chat_id, call.message.id, 
                            parse_mode="Markdown", reply_markup=main_menu())
        bot.answer_callback_query(call.id)
        return
    
    if action == "stats":
        stats = USER_STATS.get(chat_id, {"requests": 0, "cities": set()})
        text = f"📊 *Твоя статистика:*\n📈 Запросов: {stats['requests']}\n🏙️ Городов: {len(stats['cities'])}"
        bot.edit_message_text(text, chat_id, call.message.id, parse_mode="Markdown", reply_markup=action_menu())
        bot.answer_callback_query(call.id)
        return
    
    WAITING_FOR_ACTION[chat_id] = action
    bot.answer_callback_query(call.id)
    bot.edit_message_text(
        f"📝 *{action_names.get(action, action)}*\n\n💬 Введи город:",
        chat_id, call.message.id, parse_mode="Markdown",
        reply_markup=types.InlineKeyboardMarkup().add(
            types.InlineKeyboardButton("🔙 Главное меню", callback_data="main_menu")
        )
    )

