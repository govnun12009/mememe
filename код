        time.sleep(1800)  
        for chat_id, city in list(SUBSCRIPTIONS.items()):
            try:
                temp, text = get_weather(city)
                if temp:
                    bot.send_message(chat_id, f"⏰ *{city}:*\n\n{text}", 
