def get_weather_data(lat: float, lon: float):
    url = (
        "https://api.open-meteo.com/v1/forecast?"
        f"latitude={lat}&longitude={lon}&"
        "current=temperature_2m,relative_humidity_2m,wind_speed_10m,weather_code,pressure_msl&"
        "daily=temperature_2m_max,temperature_2m_min,weather_code&"
        "hourly=temperature_2m,precipitation_probability&"
        "timezone=auto"
    )
    try:
        resp = requests.get(url, timeout=30)
        return resp.json() if resp.status_code == 200 else None
    except:
        return None

def get_weather_by_coords(lat: float, lon: float):
    """🌍 Погода по координатам"""
    data = get_weather_data(lat, lon)
    if not data: return None, "❌ Ошибка погоды"
    
    current = data["current"]
    temp = current["temperature_2m"]
    humidity = current["relative_humidity_2m"]
    wind = current["wind_speed_10m"]
    code = current["weather_code"]
    pressure = current["pressure_msl"]
    
    precip = 0
    if "hourly" in data and len(data["hourly"]["precipitation_probability"]) > 0:
        precip = data["hourly"]["precipitation_probability"][0]
    
    icon = WEATHER_ICONS.get(code, "🌤️")
    advice = get_clothing_advice(temp, wind, precip)
    
    location_text = f"📍 *Твоё местоположение*\n🌐 lat:{lat:.2f} lon:{lon:.2f}"
    
    text = (
        f"{location_text}\n\n"
        f"{icon} *Погода здесь*\n\n"
        f"🌡 {temp}°C {icon}\n"
        f"💧 {humidity}% • 💨 {wind}м/с\n"
        f"📉 {pressure:.0f}гПа\n\n"
        f"{advice}"
    )
    return temp, text

def get_weather(city_input: str, forecast_days: int = 1):
    city = city_input.strip()
    lat, lon, city_name = get_coords_from_name(city)
    
    if not city: return None, "❌ Пустой запрос."
    if lat is None: return None, f"❌ Город `{city}` не найден."
    
    data = get_weather_data(lat, lon)
    if not data: return None, "❌ Ошибка погоды."
    
    current = data["current"]
    temp = current["temperature_2m"]
    humidity = current["relative_humidity_2m"]
    wind = current["wind_speed_10m"]
    code = current["weather_code"]
    pressure = current["pressure_msl"]
    
    precip = 0
    if "hourly" in data and len(data["hourly"]["precipitation_probability"]) > 0:
        precip = data["hourly"]["precipitation_probability"][0]
    
    icon = WEATHER_ICONS.get(code, "🌤️")
    advice = get_clothing_advice(temp, wind, precip)
    
    forecast = ""
    if "daily" in data:
        daily = data["daily"]
        days = ["Сегодня", "Завтра", "Пн", "Вт", "Ср", "Чт", "Пт"][:forecast_days]
        for i, day in enumerate(days):
            if i < len(daily["time"]):
                t_max = daily["temperature_2m_max"][i]
                t_min = daily["temperature_2m_min"][i]
                day_icon = WEATHER_ICONS.get(daily["weather_code"][i], "🌤️")
                forecast += f"{day_icon} {day}: {t_max}°/{t_min}°\n"
    
    text = (
        f"{icon} *{city_name}*\n\n"
        f"🌡 {temp}°C {icon}\n"
        f"💧 {humidity}% • 💨 {wind}м/с\n"
        f"📉 {pressure:.0f}гПа\n\n"
        f"{advice}\n\n"
        f"📅 *Прогноз:*\n{forecast}"
    )
    return temp, text

def get_clothing_advice(temp: float, wind: float = 0, precip: int = 0) -> str:
    feels_like = temp - (wind * 0.3)
    rain_advice = " ☔ Возьми зонт!" if precip > 50 else ""
    
    if feels_like >= 28:
        return f"🏖️ **ЖАРА** (+28°C+)\n👕 Майка + шорты\n🩴 Шлёпанцы\n🧢 Панама{rain_advice}"
    elif feels_like >= 22:
        return f"☀️ **ТЕПЛО** (+22-28°C)\n👕 Футболка + шорты\n👖 Лёгкие брюки\n🤿 Сандалии{rain_advice}"
    elif feels_like >= 16:
        return f"🌤️ **КОМФОРТНО** (+16-22°C)\n👕 Футболка + чиносы\n🧥 Лёгкая ветровка\n👟 Кроссовки{rain_advice}"
    elif feels_like >= 10:
        return f"🌦️ **Прохладно** (+10-16°C)\n👕 Лонгслив + джинсы\n🧥 Флис + куртка\n🧣 Шарф\n👢 Ботинки{rain_advice}"
    elif feels_like >= 4:
        return f"🍂 **ОСЕНЬ** (+4-10°C)\n👕 Водолазка + свитер\n🧥 Демисезонка\n🧤 Перчатки\n🧣 Шарф + шапка{rain_advice}"
    elif feels_like >= -3:
        return f"❄️ **ЗИМА** (-3-4°C)\n👚 Термобельё + флис\n🧥 Пуховик\n🧣 Шарф + шапка\n🧤 Вязаные перчатки{rain_advice}"
    elif feels_like >= -10:
        return f"🥶 **МОРОЗ** (-10--3°C)\n🔥 Термобельё 2сл + пуховик\n🧣 Шарф + балаклава\n🧤 Тёплые варежки\n👢 Сапоги{rain_advice}"
    else:
        return f"🌨️ **СИЛЬНЫЙ МОРОЗ** (<-10°C)\n🔥 Термобельё + пуховик с мехом\n❄️ Балаклава + очки\n🧤 Мембранные варежки\n🦺 Термосумка{rain_advice}"

def get_coords_from_name(city: str):
    url = f"https://geocoding-api.open-meteo.com/v1/search?name={city}&count=1&language=ru"
    try:
        resp = requests.get(url, timeout=15)
        data = resp.json()
        if resp.status_code == 200 and data.get("results"):
            result = data["results"][0]
            return result["latitude"], result["longitude"], result["name"]
    except:
        pass
    return None, None, None

def get_hourly_forecast(city: str):
    lat, lon, city_name = get_coords_from_name(city)
    if not lat: return "❌ Город не найден"
    
    data = get_weather_data(lat, lon)
    if not data or "hourly" not in data: return "❌ Нет данных"
    
    hourly = data["hourly"]
    now = datetime.now().hour
    text = f"📊 *{city_name} — 12ч:*\n\n"
    
    for i in range(12):
        hour = (now + i) % 24
        temp = round(hourly["temperature_2m"][i], 1)
        precip = hourly["precipitation_probability"][i]
        icon = "🌧️" if precip > 50 else "☀️"
        text += f"{hour:02d}:00 {icon} {temp}° ({precip}%)\n"
    
    return text

def compare_cities(city_input: str):
    cities = [c.strip() for c in city_input.split(",")][:3]
    results = []
    for city in cities:
        temp, _ = get_weather(city)
        if temp: results.append((city, temp))
    
    if not results: return "❌ Города не найдены"
    results.sort(key=lambda x: x[1], reverse=True)
    text = "🥇🥈🥉 *Рейтинг:*\n\n"
    medals = ["🥇", "🥈", "🥉"]
    for i, (city, temp) in enumerate(results):
        text += f"{medals[i]} {city}: *{temp}°C*\n"
    return text

